{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:8090",

  "App": {
    "LlmProvider":   "ollama",

    "GeminiApiKey":  "",
    "GeminiModel":   "gemini-2.5-flash",

    "GroqApiKey":    "",
    "GroqModel":     "gemma2-9b-it",

    "OllamaBaseUrl": "http://localhost:11434",
    "OllamaModel":   "mistral:latest",

    "Temperature":   0.7,
    "MaxTokens":     512,
    "DemoMode":      false
  },

  "Serilog": {
    "MinimumLevel": {
      "Default":   "Information",
      "Override": {
        "Microsoft": "Warning",
        "System":    "Warning"
      }
    }
  }
}
